#!/usr/bin/env bash

export XDG_RUNTIME_DIR="/tmp/${UID}"

echo $port, $host
module load uv
source /curc/sw/uv_env/llm-chatbot-env/bin/activate

# Optional per-user environment overrides
if [[ -f "${HOME}/.curc_chat_env" ]]; then
  # shellcheck disable=SC1091
  source "${HOME}/.curc_chat_env"
fi

if [[ "<%= context.model_path %>" == "CURC LLM Models" ]]
then
  ml ollama
else
  export OLLAMA_MODELS=<%= context.model_path %>; ml ollama
fi

# Location of chat history (use projects instead of scratch)
export CHAINLIT_DATA_DIR="/projects/${USER}/.chainlit_data"

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHAINLIT_APP_DIR=""
for _candidate in \
  "${CHAINLIT_APP_DIR:-}" \
  "/curc/sw/uv_env/llm-chatbot-env/app" \
  "${_script_dir}/app" \
  "${_script_dir}/bin"; do
  if [[ -n "${_candidate}" && -f "${_candidate}/app.py" ]]; then
    CHAINLIT_APP_DIR="${_candidate}"
    break
  fi
done

if [[ -z "${CHAINLIT_APP_DIR}" ]]; then
  echo "ERROR: Chainlit app not found."
  echo "Expected app.py under one of:"
  echo "  /curc/sw/uv_env/llm-chatbot-env/app"
  echo "  ${_script_dir}/app"
  echo "  ${_script_dir}/bin"
  echo "Populate the shared path when releasing: rsync -a app/ /curc/sw/uv_env/llm-chatbot-env/app/"
  exit 1
fi

sleep 5

cd "${CHAINLIT_APP_DIR}"
echo "CURC chat app dir: $(pwd)"
chainlit run --root-path /node/${host}/${port} --port $port --debug --host $(hostname -I) app.py
