#!/usr/bin/env bash

export XDG_RUNTIME_DIR="/tmp/${UID}"

echo $port, $host
module load uv 
source /curc/sw/uv_env/llm-chatbot-env/bin/activate

# Free local voice: faster-whisper (STT on GPU) + edge-tts (spoken replies)
export HF_HOME="${HF_HOME:-/projects/${USER}/.cache/huggingface}"
mkdir -p "$HF_HOME"

python -m pip install --quiet "faster-whisper>=1.0.0" "edge-tts>=6.1.0"
if ! python -c "import faster_whisper, edge_tts" 2>/dev/null; then
  echo "ERROR: voice packages failed to install; speech input/output will not work."
fi

# Optional per-user voice tuning (model size, TTS voice, etc.)
if [[ -f "${HOME}/.curc_chat_env" ]]; then
  # shellcheck disable=SC1091
  source "${HOME}/.curc_chat_env"
fi

if [[ "<%= context.model_path %>" == "CURC LLM Models" ]]
then
  ml ollama
else
  export OLLAMA_MODELS=<%= context.model_path %>; ml ollama
fi

# Location of chat history (use projects instead of scratch)
export CHAINLIT_DATA_DIR="/projects/${USER}/.chainlit_data"

sleep 5 

cd bin 
echo "CURC chat app dir: $(pwd)"
grep -E "spontaneous_file_upload|enabled" .chainlit/config.toml | head -5 || true
test -f curc_chat/hpc_files.py && echo "HPC path attachments: curc_chat/hpc_files.py present" || echo "WARNING: hpc_files.py missing"
chainlit run --root-path /node/${host}/${port} --port $port --debug --host $(hostname -I) app.py
