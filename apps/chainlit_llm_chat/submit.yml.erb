<%-

  # Initialize an empty array to hold Slurm arguments
  #
  # NOTE: Preset-only mode.
  # `config_type` is intentionally disabled in `form.yml.erb`, so users cannot
  # submit custom Slurm directives. Keep the legacy custom branch commented
  # further down for future restoration.
  base_slurm_args = ["--nodes=1", "--partition=atesting_a100", "--qos=testing"]

  case preset_configuration
    # set tasks and time based on provided selection
    when "10x1x1alpine"
      base_slurm_args += ["--ntasks=10", "--time=1:00:00", "--gres=gpu:1"]
    else
      base_slurm_args
  end

-%>
---

# if presets set cluster to Alpine and use base_slurm_args to set Slurm directives 
cluster: "alpine"
script:
  copy_environment: true
  native:
    <% base_slurm_args.each do |arg| %>
      - <%= arg %>
    <% end %>

