<%-

  # Initialize an empty array to hold Slurm arguments
  base_slurm_args = ["--nodes=1", "--partition=atesting_a100", "--qos=testing"]

  if config_type == "presets"
    case preset_configuration
      when "10x1x1alpine"
        base_slurm_args += ["--ntasks=10", "--time=1:00:00", "--gres=gpu:1"]
      else
        base_slurm_args
    end
  end

  if config_type == "custom"
    gres_value = gres.to_s.strip.downcase
    gpu_count = 0
    unless gres_value.blank? || gres_value == "none"
      gres_value.scan(/gpu(?::[a-z0-9_-]+)*:(\d+)/i).each do |match|
        gpu_count += match[0].to_i
      end
    end
    if gpu_count < 1
      raise "Custom configuration requires at least one GPU in gres (for example: gpu:1 or gpu:a100:1). Voice and local inference need a GPU on the compute node."
    end
  end

-%>
---

<% if config_type == "presets" -%>

cluster: "alpine"
script:
  copy_environment: true
  native:
    <% base_slurm_args.each do |arg| %>
      - <%= arg %>
    <% end %>

<% else -%>

cluster: "<%= cluster %>"
script:
  copy_environment: true
  native:
    - "--nodes=1"
    - "--ntasks=<%= num_cores %>"
    - "--account=<%= account %>"
    - "--partition=<%= partition_name %>"
    - "--qos=<%= qos_name %>"
    - "--time=<%= num_hours %>:00:00"
    <% if reservation.downcase != "none" %>
    - "--reservation=<%= reservation %>"
    <% end %>
    - "--gres=<%= gres %>"
    <% if nodelist.downcase != "none" %>
    - "--nodelist=<%= nodelist %>"
    <% end %>
    <% if constraint.downcase != "none" %>
    - "--constraint=<%= constraint %>"
    <% end %>

<% end -%>

batch_connect:
  template: "basic"
